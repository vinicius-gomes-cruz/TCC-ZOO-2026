@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Diagrama de Componentes - API Backend (C3)

' Componentes dentro do container API
Container_Boundary(API_Container, "API Backend - Spring Boot") {
    Component(AnimalController, "AnimalController", "Recebe requisições REST para operações com animais", "Spring MVC")
    Component(UsuarioController, "UsuarioController", "Recebe requisições REST para operações com usuários", "Spring MVC")

    Component(AnimalService, "AnimalService", "Regras de negócio relacionadas a animais", "Java")
    Component(UsuarioService, "UsuarioService", "Regras de negócio relacionadas a usuários", "Java")

    Component(AnimalRepository, "AnimalRepository", "Acesso a dados (JPA) para animais", "JPA/Hibernate")
    Component(UsuarioRepository, "UsuarioRepository", "Acesso a dados (JPA) para usuários", "JPA/Hibernate")
}

ContainerDb(DB, "Banco de Dados", "MySQL", "Persistência de dados")

' Relacionamentos principais
Rel(AnimalController, AnimalService, "Chama")
Rel(UsuarioController, UsuarioService, "Chama")

Rel(AnimalService, AnimalRepository, "Usa")
Rel(UsuarioService, UsuarioRepository, "Usa")

Rel(AnimalRepository, DB, "Lê/Escreve")
Rel(UsuarioRepository, DB, "Lê/Escreve")

@enduml