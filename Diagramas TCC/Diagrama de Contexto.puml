@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Sistema de Gerenciamento de Zoológico - Diagrama de Contexto (C1)

' Atores / Pessoas
Person(Funcionario, "Funcionário", "Gerencia operações do zoológico")
Person(Administrador, "Administrador", "Administração do sistema")

' Sistema principal
System(Sistema, "Sistema de Gerenciamento do Zoológico", "Gerencia animais, habitats, estoque e usuários")

' Relacionamentos
Rel(Funcionario, Sistema, "Utiliza")
Rel(Administrador, Sistema, "Administra")

@enduml