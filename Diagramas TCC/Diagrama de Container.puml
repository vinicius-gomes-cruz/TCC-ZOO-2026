@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Sistema de Gerenciamento de Zoológico – Diagrama de Containers (C2)

' Pessoas (atores)
Person(Funcionario, "Funcionário", "Gerencia operações")
Person(Administrador, "Administrador", "Funções administrativas")

' Sistema e containers
System_Boundary(Sistema, "Sistema de Gerenciamento do Zoológico") {
    Container(WebApp, "Aplicação Web", "React", "Interface do usuário; consome API REST")
    Container(API, "API Backend", "Spring Boot", "Regras de negócio; autenticação; documentação")
    ContainerDb(DB, "Banco de Dados", "MySQL", "Armazena animais, habitats, estoque e usuários")
}

' Relacionamentos
Rel(Funcionario, WebApp, "Gerencia operações")
Rel(Administrador, WebApp, "Administra")
Rel(Administrador, API, "Acessa Swagger")
Rel(WebApp, API, "HTTP/JSON")
Rel(API, DB, "JPA/Hibernate")

@enduml